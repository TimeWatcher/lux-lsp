    {
      "path": "hook.Add",
      "kind": "function",
      "realm": "shared",
      "summary": "Registers a function for a named hook event.",
      "description": ["The hook name controls callback parameters. Lux LSP uses hook data to show hook-name hover and callback signature help."],
      "signatures": [
        {
          "label": "hook.Add(eventName, identifier, callback)",
          "parameters": [
            {"name": "eventName", "ty": "string", "description": "Hook name, for example \"PlayerInitialSpawn\"."},
            {"name": "identifier", "ty": "string|table", "description": "Unique identifier used to replace or remove the hook."},
            {"name": "callback", "ty": "function", "description": "Function called when the hook fires."}
          ]
        }
      ],
      "examples": [
        {"title": "Player spawn callback", "language": "lua", "code": "hook.Add(\"PlayerInitialSpawn\", \"Welcome\", function(ply)\n  print(ply:Nick())\nend)"}
      ],
      "official_url": "https://wiki.facepunch.com/gmod/hook.Add"
    },
