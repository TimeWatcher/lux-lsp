    {
      "path": "AddCSLuaFile",
      "kind": "function",
      "realm": "server",
      "summary": "Marks a Lua file to be sent from the server to clients.",
      "description": ["Lux's GMod backend normally emits loader code for client files, so hand-written `AddCSLuaFile` is usually unnecessary in Lux packages."],
      "signatures": [
        {
          "label": "AddCSLuaFile(path)",
          "parameters": [
            {"name": "path", "ty": "string", "description": "Lua path relative to the gamemode or addon lua directory."}
          ]
        }
      ],
      "warnings": ["Server-only. Calling it from shared/client Lux code is a realm error."],
      "examples": [
        {"title": "Legacy GLua usage", "language": "lua", "code": "if SERVER then\n  AddCSLuaFile(\"cl_hud.lua\")\nend"}
      ],
      "official_url": "https://wiki.facepunch.com/gmod/Global.AddCSLuaFile"
    },
