      "path": "net",
      "kind": "library",
      "realm": "shared",
      "summary": "Networking library for sending structured messages between server and client.",
      "official_url": "https://wiki.facepunch.com/gmod/net"
    },
    {
      "path": "net.Start",
      "kind": "function",
      "realm": "shared",
      "summary": "Begins writing a net message with a registered network string.",
      "description": ["On the server, the name must be registered with `util.AddNetworkString` before clients can receive it. After `net.Start`, write payload data and finish with a send function such as `net.Send`, `net.Broadcast`, or `net.SendToServer`."],
      "signatures": [
        {
          "label": "net.Start(messageName, unreliable = false)",
          "parameters": [
            {"name": "messageName", "ty": "string", "description": "Registered network message name."},
            {"name": "unreliable", "ty": "boolean", "description": "Whether to use the unreliable channel.", "optional": true}
          ],
          "returns": [
            {"ty": "boolean", "description": "Whether the message could be started."}
          ]
        }
      ],
      "warnings": ["A net message must be completed with exactly one send function."],
      "examples": [
        {"title": "Server to all clients", "language": "lua", "code": "util.AddNetworkString(\"LuxNotice\")\nnet.Start(\"LuxNotice\")\nnet.WriteString(\"Ready\")\nnet.Broadcast()"}
      ],
      "related": ["util.AddNetworkString", "net.Receive", "net.Broadcast", "net.Send", "net.SendToServer"],
      "official_url": "https://wiki.facepunch.com/gmod/net.Start"
    },
    {
      "path": "net.Receive",
      "kind": "function",
      "realm": "shared",
      "summary": "Registers a callback for a net message.",
      "description": ["The callback receives the message length and, on the server, the player who sent the message. Client callbacks do not receive a player argument."],
      "signatures": [
        {
          "label": "net.Receive(messageName, callback)",
          "parameters": [
            {"name": "messageName", "ty": "string", "description": "Network message name."},
            {"name": "callback", "ty": "function(len: number, ply?: Player)", "description": "Handler called when the message arrives."}
          ]
        }
      ],
      "examples": [
        {"title": "Receive a message", "language": "lua", "code": "net.Receive(\"LuxNotice\", function(len, ply)\n  print(net.ReadString())\nend)"}
      ],
      "official_url": "https://wiki.facepunch.com/gmod/net.Receive"
    },
