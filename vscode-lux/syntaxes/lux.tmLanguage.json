{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Lux",
  "scopeName": "source.lux",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#gmodGlobals"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.lux",
          "begin": "--\\[\\[",
          "end": "\\]\\]"
        },
        {
          "name": "comment.line.double-dash.lux",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.lux",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.lux",
              "match": "\\\\(?:[abfnrtv\\\\\"']|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        },
        {
          "name": "string.quoted.single.lux",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.lux",
              "match": "\\\\(?:[abfnrtv\\\\\"']|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        },
        {
          "name": "string.interpolated.template.lux",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "constant.character.escape.lux",
              "match": "\\\\[`\\\\$]"
            },
            {
              "name": "meta.embedded.expression.lux",
              "begin": "\\$\\{",
              "beginCaptures": {
                "0": {
                  "name": "punctuation.section.embedded.begin.lux"
                }
              },
              "end": "\\}",
              "endCaptures": {
                "0": {
                  "name": "punctuation.section.embedded.end.lux"
                }
              },
              "patterns": [
                {
                  "include": "$self"
                }
              ]
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.lux",
          "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
        },
        {
          "name": "constant.numeric.float.lux",
          "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?\\b"
        },
        {
          "name": "constant.numeric.integer.lux",
          "match": "\\b\\d[\\d_]*\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.function.lux",
          "match": "\\b(?:(export)\\s+)?(?:(client|server|shared)\\s+)?(fn)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.export.lux"
            },
            "2": {
              "name": "storage.modifier.realm.lux"
            },
            "3": {
              "name": "storage.type.function.lux"
            },
            "4": {
              "name": "entity.name.function.lux"
            }
          }
        },
        {
          "name": "meta.declaration.constant.lux",
          "match": "\\b(?:(export)\\s+)?(?:(client|server|shared)\\s+)?(const|local)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.control.export.lux"
            },
            "2": {
              "name": "storage.modifier.realm.lux"
            },
            "3": {
              "name": "storage.type.variable.lux"
            },
            "4": {
              "name": "variable.other.definition.lux"
            }
          }
        },
        {
          "name": "meta.declaration.enum.lux",
          "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(repr)\\s+(number|string|table|existing))?",
          "captures": {
            "1": {
              "name": "storage.type.enum.lux"
            },
            "2": {
              "name": "entity.name.type.enum.lux"
            },
            "3": {
              "name": "keyword.other.repr.lux"
            },
            "4": {
              "name": "support.type.repr.lux"
            }
          }
        },
        {
          "name": "meta.declaration.extern.lux",
          "match": "\\b(extern)\\s+(client|server|shared)\\s+([A-Za-z_][A-Za-z0-9_]*(?:[\\.:][A-Za-z_][A-Za-z0-9_]*)*)",
          "captures": {
            "1": {
              "name": "keyword.control.extern.lux"
            },
            "2": {
              "name": "storage.modifier.realm.lux"
            },
            "3": {
              "name": "support.other.external.lux"
            }
          }
        },
        {
          "name": "meta.import.lux",
          "match": "\\b(import)\\b|\\b(from)\\b|\\b(as)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.import.lux"
            },
            "2": {
              "name": "keyword.control.from.lux"
            },
            "3": {
              "name": "keyword.control.as.lux"
            }
          }
        },
        {
          "name": "keyword.control.export.lux",
          "match": "\\bexport\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "storage.modifier.realm.lux",
          "match": "\\b(client|server|shared)\\b(?=\\s*(?:fn|const|local|\\{))"
        },
        {
          "name": "keyword.control.flow.lux",
          "match": "\\b(match|then|else|if|while|for|in|return|break|continue|do|stopif|stopifn)\\b"
        },
        {
          "name": "keyword.operator.logical.lux",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "storage.type.lux",
          "match": "\\b(fn|const|local|macro|host|phase|runtime|compiletime)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.lux",
          "match": "=>|->"
        },
        {
          "name": "keyword.operator.optional.lux",
          "match": "\\?\\.|\\?:|\\?\\?|\\?"
        },
        {
          "name": "keyword.operator.pipeline.lux",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.assignment.lux",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.comparison.lux",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.lux",
          "match": "\\+|-|\\*|/|%|\\.\\."
        },
        {
          "name": "punctuation.separator.lux",
          "match": "[,;:]"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.lux",
          "match": "\\b(true|false|nil)\\b"
        },
        {
          "name": "variable.language.self.lux",
          "match": "\\b(self)\\b"
        }
      ]
    },
    "gmodGlobals": {
      "patterns": [
        {
          "name": "support.constant.realm.gmod.lux",
          "match": "\\b(SERVER|CLIENT|MENU_DLL)\\b"
        },
        {
          "name": "support.function.gmod.lux",
          "match": "\\b(AddCSLuaFile|include|hook\\.Add|hook\\.Remove|net\\.Start|net\\.Receive|vgui\\.Create|LocalPlayer|IsValid)\\b"
        }
      ]
    }
  }
}
